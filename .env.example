# Required for real LLM-backed runs.
# Demo mode works without this key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: Jarvis can create Jira issues when these are set.
# Without these, Jarvis still generates and exports tickets locally.
JIRA_INSTANCE_URL=https://your-company.atlassian.net
JIRA_SERVICE_ACCOUNT_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Optional: Jarvis can read Figma designs when configured.
FIGMA_SERVICE_ACCOUNT_TOKEN=

# Optional: Cortana can use an external Qdrant store when configured.
# The default demo path uses local sample documents.
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=personal_agent_docs
QDRANT_API_KEY=

# Optional: future connector examples.
GOOGLE_SERVICE_ACCOUNT_JSON=
GDRIVE_FOLDER_ID=
CONFLUENCE_INSTANCE_URL=
CONFLUENCE_PAGE_URLS=

